# MediQuery — environment variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Your HF token from https://huggingface.co/settings/tokens
# Needs at least "read" access. "Inference API" must be enabled for your account.
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bi-encoder embedding model — must match the dimension of your Pinecone index.
# Default: all-MiniLM-L6-v2 (384-dim, general NLP)
# Upgrade: pritamdeka/S-PubMedBert-MS-MARCO (768-dim, biomedical — requires index rebuild)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM for answer generation — swap for any HF-hosted instruction-tuned model
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras

# Cross-encoder for reranking retrieved passages (retrieve 8, rerank → top 3)
HF_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Pinecone ──────────────────────────────────────────────────────────────────
# From https://app.pinecone.io → your project → API Keys
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The name you gave your index (dimension: 384, metric: cosine)
PINECONE_INDEX_NAME=mediquery

# The host URL for your index — found in the Pinecone console under the index details
# Format: https://<index-name>-<project-id>.svc.<environment>.pinecone.io
PINECONE_HOST=https://mediquery-xxxxxxx.svc.aped-xxxx-xxxx.pinecone.io

# ── Optional tuning ───────────────────────────────────────────────────────────
# Number of candidates retrieved from Pinecone before reranking (default: 8)
TOP_K=8
MAX_NEW_TOKENS=512
